JWT_ACCESS_SECRET=
HOST_PROJECTS_ROOT=/app/workspace
REAPER_POD_MEMORY_LIMIT=8g
REAPER_POD_CPU_LIMIT=4
REAPER_POD_PIDS_LIMIT=4096
# Public DNS name or IP address used to reach Reaper.
REAPER_HOST=
# Optional domain for <route>.<domain> publishing. Leave empty for IP publishing.
APEX_DOMAIN=
# Must match APEX_DOMAIN for domain publishing; leave empty for IP publishing.
COOKIE_DOMAIN=

APP_ADMIN_USERNAME=
APP_ADMIN_PASSWORD=
ALLOW_SELF_SIGNUP=false
COOKIE_SECURE=true
GLOBAL_RATE_LIMIT_WINDOW_MS=900000
GLOBAL_RATE_LIMIT_MAX=1200
AUTH_RATE_LIMIT_WINDOW_MS=1200000
AUTH_RATE_LIMIT_MAX=25
LOGIN_FAILURE_LIMIT=3
LOGIN_IP_FAILURE_LIMIT=10
LOGIN_FAILURE_WINDOW_MS=1200000
LOGIN_LOCKOUT_MS=1200000

